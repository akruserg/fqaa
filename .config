CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
CONFIG_TARGET_ramips_mt76x8_DEVICE_keenetic_kn-1121=y

# База и Русский язык
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-ru=y

# Интернет (PPPoE)
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# PassWall (только на ядре Sing-Box)
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-ru=y
CONFIG_PACKAGE_sing-box=y

# Ускорение (чтобы процессор не грелся)
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-nf-flow-offload=y
